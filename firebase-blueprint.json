{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "grauMaconico": {
          "type": "number"
        },
        "role": {
          "type": "string",
          "enum": ["aluno", "adminPremium"]
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": ["email", "grauMaconico", "role", "createdAt", "updatedAt"]
    },
    "Course": {
      "title": "Course",
      "description": "Course or Book generated by AI.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        },
        "grauPermitido": {
          "type": "number"
        },
        "grauDoCurso": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["rascunho", "publicado", "arquivado"]
        },
        "premium": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": ["curso", "livro", "curso_livro"]
        }
      },
      "required": ["title", "createdBy", "createdAt", "updatedAt", "grauPermitido", "status", "type"]
    },
    "Module": {
      "title": "Module",
      "description": "Module within a course.",
      "type": "object",
      "properties": {
        "courseId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": ["courseId", "title", "order", "createdAt"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Unit within a module.",
      "type": "object",
      "properties": {
        "moduleId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": ["moduleId", "title", "order", "createdAt"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Lesson within a unit.",
      "type": "object",
      "properties": {
        "unitId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "content": {
          "type": "string"
        },
        "exercises": {
          "type": "array"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": ["unitId", "title", "order", "content", "createdAt"]
    },
    "Attempt": {
      "title": "Attempt",
      "description": "User attempt on an evaluation.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "courseId": {
          "type": "string"
        },
        "moduleId": {
          "type": "string"
        },
        "unitId": {
          "type": "string"
        },
        "lessonId": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "passed": {
          "type": "boolean"
        },
        "answers": {
          "type": "object"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": ["userId", "courseId", "score", "passed", "createdAt"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User progress in a course.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "courseId": {
          "type": "string"
        },
        "completedLessons": {
          "type": "array"
        },
        "completedUnits": {
          "type": "array"
        },
        "completedModules": {
          "type": "array"
        },
        "overallProgress": {
          "type": "number"
        },
        "lockedUntilPass": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": ["userId", "courseId", "updatedAt"]
    },
    "LibraryCategory": {
      "title": "LibraryCategory",
      "description": "Categories for cataloged virtual library items.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "TroncoDoacao": {
      "title": "TroncoDoacao",
      "description": "Anonymous donation to the Lodge's general charity bag.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "loja": {
          "type": "string"
        },
        "isSacolaLimpa": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "object"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "sacola_limpa"]
        }
      },
      "required": ["amount", "loja", "isSacolaLimpa", "status"]
    },
    "TroncoLoja": {
      "title": "TroncoLoja",
      "description": "Consolidated general charity bag balances for each Lodge.",
      "type": "object",
      "properties": {
        "totalBalance": {
          "type": "number"
        },
        "donationsCount": {
          "type": "number"
        },
        "sacolasLimpaCount": {
          "type": "number"
        },
        "lastUpdate": {
          "type": "object"
        }
      },
      "required": ["totalBalance", "donationsCount", "sacolasLimpaCount"]
    }
  },
  "firestore": {
    "/tronco_doacoes/{doacaoId}": {
      "schema": {
        "$ref": "#/entities/TroncoDoacao"
      },
      "description": "Anonymous donations registry."
    },
    "/tronco_lojas/{lojaId}": {
      "schema": {
        "$ref": "#/entities/TroncoLoja"
      },
      "description": "Lodge charity balances."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/courses/{courseId}": {
      "schema": {
        "$ref": "#/entities/Course"
      },
      "description": "Stores generated courses."
    },
    "/courses/{courseId}/modules/{moduleId}": {
      "schema": {
        "$ref": "#/entities/Module"
      },
      "description": "Stores modules of a course."
    },
    "/courses/{courseId}/modules/{moduleId}/units/{unitId}": {
      "schema": {
        "$ref": "#/entities/Unit"
      },
      "description": "Stores units of a module."
    },
    "/courses/{courseId}/modules/{moduleId}/units/{unitId}/lessons/{lessonId}": {
      "schema": {
        "$ref": "#/entities/Lesson"
      },
      "description": "Stores lessons of a unit."
    },
    "/attempts/{attemptId}": {
      "schema": {
        "$ref": "#/entities/Attempt"
      },
      "description": "Stores evaluation attempts."
    },
    "/progress/{progressId}": {
      "schema": {
        "$ref": "#/entities/Progress"
      },
      "description": "Stores user progress."
    },
    "/library_categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/LibraryCategory"
      },
      "description": "Stores categories of library items."
    }
  }
}
